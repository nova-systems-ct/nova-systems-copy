# Supabase (client-side, safe to expose)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase (server-side only — Vercel serverless functions in /api)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend — transactional email
RESEND_API_KEY=

# Anthropic — AI document generation
ANTHROPIC_API_KEY=

# Google Cloud / Google Maps Platform
GOOGLE_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Nova AI — voice + SMS agent platform (/ai)
ELEVENLABS_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Optional — a Twilio Messaging Service SID. Without this, the plain Twilio Messages
# API cannot schedule a delayed send, so the /welcome 2-hour SMS follow-up (and any
# other scheduled SMS) sends immediately instead of waiting. Set this up in the
# Twilio console (Messaging > Services) to get true delayed delivery.
TWILIO_MESSAGING_SERVICE_SID=
ISAAC_ALERT_PHONE=
DEEPGRAM_API_KEY=
# wss:// URL of the separately-hosted media-stream service (see api/nova-ai/stream.js —
# Vercel serverless functions cannot hold open the WebSocket a live call needs).
NOVA_AI_STREAM_WS_URL=

# Cal.com — booking link
VITE_CALCOM_URL=
